{
  "$schema": "https://schemas.nimblebrain.ai/v1/nimblebrain-server.schema.json",
  "name": "ai.nimblebrain/git-worktree",
  "description": "Git worktree manager for isolated workspaces with branch lifecycle, risk classification, and merge control",
  "version": "0.1.0",
  "title": "Git Worktree MCP Server",
  "repository": {
    "url": "https://github.com/NimbleBrainInc/mcp-git-worktree",
    "source": "https://github.com/NimbleBrainInc/mcp-git-worktree"
  },
  "_meta": {
    "ai.nimblebrain/v1": {
      "runtime": "python:3.13",
      "capabilities": {
        "tools": true,
        "resources": false,
        "prompts": false
      },
      "display": {
        "category": "developer-tools",
        "tags": [
          "git",
          "worktree",
          "workspace",
          "version-control"
        ]
      },
      "deployment": {
        "protocol": "http",
        "port": 8000,
        "mcpPath": "/mcp",
        "source": "tenant"
      },
      "container": {
        "healthCheck": {
          "path": "/health",
          "port": 8000
        }
      },
      "resources": {
        "limits": {
          "memory": "256Mi",
          "cpu": "500m"
        },
        "requests": {
          "memory": "128Mi",
          "cpu": "100m"
        }
      },
      "scaling": {
        "minReplicas": 1,
        "maxReplicas": 1
      }
    }
  }
}
